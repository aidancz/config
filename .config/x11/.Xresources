! # define

! nofrils_dark
#define black   #2b2b2b
#define red     #dc322f
#define green   #859900
#define yellow  #b58900
#define blue    #268bd2
#define magenta #d33682
#define cyan    #2aa198
#define white   #9e9e9e
! nofrils_dark

! #2b2b2b lab color: 17.5 0 0
! #9e9e9e lab color: 65   0 0

! ! nofrils_light
! #define black   #cdcdcd
! #define red     #dc322f
! #define green   #859900
! #define yellow  #b58900
! #define blue    #268bd2
! #define magenta #d33682
! #define cyan    #2aa198
! #define white   #525252
! ! nofrils_light

! #cdcdcd lab color: 82.5 0 0
! #525252 lab color: 35   0 0

! # set

! ## global (currently used by: st nvim emacs)

*color0:  black
*color1:  red
*color2:  green
*color3:  yellow
*color4:  blue
*color5:  magenta
*color6:  cyan
*color7:  white

*color8:  black
*color9:  red
*color10: green
*color11: yellow
*color12: blue
*color13: magenta
*color14: cyan
*color15: white

! ## st

st.background:  black
st.foreground:  white
st.cursorColor: white

st.font: monospace:size=15
st.borderpx: 0
st.alpha: 1

! ## dwm

dwm.normbgcolor: black
dwm.normfgcolor: white
dwm.selbgcolor:  white
dwm.selfgcolor:  black

dwm.font: monospace:size=15
dwm.borderpx: 0
dwm.showbar: 1

! ## dmenu

dmenu.normbgcolor: black
dmenu.normfgcolor: white
dmenu.selbgcolor:  white
dmenu.selfgcolor:  black

dmenu.font: monospace:size=15
